# Environment for running appliance-core scenarios through
# ../lab-kit/bin/run-scenario.sh. Paths here are resolved relative
# to the current working directory at invocation time;
# lab/run-scenario.sh (the wrapper in this directory) cd's into the
# repo root before sourcing.

LAB_NAME=core
LAB_RESULTS_DIR=test-results

# Hyper-V target.
LAB_HV_HOST=server
LAB_HV_USER=nmadmin

# VM under test. Pick a VM name + reserved IP + MAC that doesn't
# collide with existing siblings:
#   samba-dc1   00:15:5D:0A:0A:14   10.10.10.20
#   smbproxy-1  00:15:5D:0A:0A:1E   10.10.10.30
#   core-1      00:15:5D:0A:0A:28   10.10.10.40   <- this appliance
# Add the matching dnsmasq reservation in ../lab-router/configs/.
LAB_VM_NAME=core-1
LAB_VM_IP=10.10.10.40
LAB_VM_USER=debadmin
# Until core-firstboot lands, deploy-master IS the only checkpoint
# available; lab/build-fresh-base.sh stops there. Once firstboot is
# implemented, default flips to golden-image. CLI override works
# because of the := default form.
LAB_GOLDEN_CHECKPOINT="${LAB_GOLDEN_CHECKPOINT:-deploy-master}"

# Host share for staging Hyper-V helper scripts. Mac-visible vs.
# host-visible paths.
LAB_STAGE_DIR=/Volumes/ISO/lab-scripts
LAB_HOST_STAGE_DIR='D:\ISO\lab-scripts'

# Helper scripts staged before each run.
LAB_STAGE_SOURCES="lab/hyperv/*.ps1 ../lab-kit/hypervisors/hyperv/*.ps1 ../lab-router/hypervisors/hyperv/*.ps1"

# Appliance scripts scp'd to /tmp on the VM before each run. lib/ is
# NOT included here — scenarios exercise the running image, which
# already has the libs vendored at /usr/local/lib/appliance-core/.
# The full lib/ tree is pushed by build-fresh-base.sh when it triggers
# a re-prep, not on every scenario run.
LAB_PUSH_FILES="prepare-image.sh core-sconfig.sh"
LAB_REMOTE_PUSH_DIR=/tmp

# After scp, install core-sconfig so scenarios can
# invoke it directly.
LAB_POST_PUSH_CMD='sudo install -m 0755 /tmp/core-sconfig.sh /usr/local/sbin/core-sconfig'
